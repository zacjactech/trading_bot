# Binance Futures Testnet API Credentials
# OLD portal (deprecated Aug 2025): https://testnet.binancefuture.com
# NEW Demo Trading portal: https://demo.binance.com/en/my/settings/api-management
# NEW Futures API base: https://demo-fapi.binance.com
#
# Login → API Key → Generate HMAC_SHA256 key

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# Base URL – try these in order if one fails:
# 1. https://testnet.binancefuture.com   (legacy)
# 2. https://demo-fapi.binance.com       (new Demo Trading, Sept 2025+)
# 3. https://testnet.binance.vision
BINANCE_BASE_URL=https://testnet.binancefuture.com

# Mock trading – set true to simulate orders offline (useful if testnet is geo-blocked, e.g. Nigeria)
# MOCK_TRADING=true
MOCK_TRADING=false
